generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

generator dbml {
    provider = "prisma-dbml-generator"
}

generator docs {
    provider = "node node_modules/prisma-docs-generator"
}

model User {
    // inheritances
    id        String   @id @default(uuid())
    index     Int      @unique @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    hash String

    // personal informations
    email String @unique
    name  String
    tel   String @unique

    // owned relations
    tunnels        Tunnel[]
    payments       Payment[]
    PaymentHistory PaymentHistory[]
}

model Tunnel {
    // inheritances
    id        String   @id @default(uuid())
    index     Int      @unique @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    ip       String // TODO: @unique
    serverIp String
    comment  String?

    // owned relations
    rules Rule[]

    // referenced relations
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Rule {
    // inheritances
    id        String   @id @default(uuid())
    index     Int      @unique @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    protocol String
    port     Int
    comment  String?

    // referenced relations
    tunnelId String
    tunnel   Tunnel @relation(fields: [tunnelId], references: [id], onDelete: Cascade)
}

model Payment {
    // inheritances
    id        String   @id @default(uuid())
    index     Int      @unique @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // ref: https://docs.tosspayments.com/reference#billing-%EA%B0%9D%EC%B2%B4
    billingKey String

    // 카드 정보
    issuerCode String
    number     String
    cardType   String
    ownerType  String

    // referenced relations
    userId         String
    user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
    PaymentHistory PaymentHistory[]
}

model PaymentHistory {
    // inheritances
    id        String   @id @default(uuid())
    index     Int      @unique @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    successedAt DateTime
    amount      Int

    // referenced relations
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    paymentId String?
    payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
}
