generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

generator dbml {
    provider = "prisma-dbml-generator"
}

generator docs {
    provider = "node node_modules/prisma-docs-generator"
}

model User {
    // inheritances
    id        String   @id @default(uuid())
    index     Int      @unique @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // personal informations
    email String @unique
    name  String
    tel   String @unique
    pfp   String
    hash  String

    // owned relations
    tunnels  Tunnel[]
    payments Payment[]
}

model Tunnel {
    // inheritances
    id        String   @id @default(uuid())
    index     Int      @unique @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    ip       String // TODO: @unique
    serverIp String
    type     String
    comment  String?

    // owned relations
    rules Rule[]

    // referenced relations
    userId String
    user   User   @relation(fields: [userId], references: [id])
}

model Rule {
    // inheritances
    id        String   @id @default(uuid())
    index     Int      @unique @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    protocol String
    port     Int
    comment  String?

    // referenced relations
    tunnelId String
    tunnel   Tunnel @relation(fields: [tunnelId], references: [id])
}

model Payment {
    // inheritances
    id        String   @id @default(uuid())
    index     Int      @unique @default(autoincrement())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // ref: https://docs.tosspayments.com/reference#billing-%EA%B0%9D%EC%B2%B4
    billingKey String

    // 카드 정보
    issuerCode String
    number     String
    cardType   String
    ownerType  String

    // referenced relations
    userId String
    user   User   @relation(fields: [userId], references: [id])
}
